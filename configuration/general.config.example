# NuupXe General Configuration Example
# Copy this file to general.config and customize for your installation

[irlp]
# Path to IRLP installation (trailing slash required)
path = /home/irlp/
# COS timer in seconds - how long to wait between COS checks
costimer = 1

[general]
# Your station callsign
callsign = XE1ABC
# Radio club name
radioclub = Radio Club Ejemplo
# Repeater output frequency (MHz)
frequency = 146.940
# Location description
location = Ciudad de Mexico
# GPS coordinates for APRS (DDmm.mmN/DDDmm.mmW format)
coordinates = 1921.00N/09908.00W
# Serial port for PTT hardware (e.g. /dev/ttyUSB0)
serialport = /dev/ttyUSB0
# Twitter account handle (optional)
twitter = @NuupXe
# Morse code agent: pygame (uses .ogg files) or cwpcm (IRLP hardware)
morseagent = pygame

[weather]
# Weather agent: openweathermap or aprsfi
agent = openweathermap
# City name for weather lookup
location = Guadalajara, Mexico
# APRS.fi callsign (used when agent=aprsfi)
aprsficallsign = XE1GYQ-13
# APRS.fi location label (used when agent=aprsfi)
aprsfilocation = Guadalajara

[system]
# Twitter/APRS hashtag
hashtag = #NuupXe
# System notification email
email = sysop@example.com
